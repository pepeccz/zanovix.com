---
/**
 * BrandMark — Zanovix isotipo de 8 pétalos
 * SVG inline trazado a mano con simetría rotacional.
 * <!-- TODO: replace with official vector when brand kit ships -->
 *
 * ADR-007: SVG inline stand-in. Fallback PNG si redesign oficial llega.
 * Uso permitido: header, footer, favicon. NUNCA inline en body como motion-language.
 */
interface Props {
  size?: number
  class?: string
}

const { size = 32, class: className = '' } = Astro.props
---

<!--
  Isotipo Zanovix: 8 pétalos simétricos alrededor de un centro circular.
  Construcción: pétalo base en posición 0°, rotado 8 veces × 45°.
  Centro: círculo sólido ink. Pétalos: trazo ink grueso, relleno paper.
  Acento teal en el borde exterior de los pétalos.
  TODO: replace with official vector when brand kit ships
-->
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Zanovix"
  class:list={[
    'transition-opacity duration-200 hover:opacity-75',
    className,
  ]}
>
  <!-- Pétalos: 8 unidades, rotación 45° cada una alrededor del centro (32,32) -->
  <!-- Pétalo base: elipse vertical estrecha centrada arriba del centro -->

  <!-- Pétalo 0° (arriba) -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(0 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 45° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(45 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 90° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(90 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 135° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(135 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 180° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(180 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 225° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(225 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 270° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(270 32 32)"
    opacity="0.92"
  />
  <!-- Pétalo 315° -->
  <ellipse
    cx="32" cy="18" rx="5.5" ry="12"
    fill="currentColor"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(315 32 32)"
    opacity="0.92"
  />

  <!-- Centro circular sólido ink -->
  <circle cx="32" cy="32" r="6.5" fill="currentColor" />
</svg>

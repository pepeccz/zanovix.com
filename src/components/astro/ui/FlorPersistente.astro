---
/**
 * FlorPersistente — flor 8 pétalos fija bottom-right en /
 *
 * Visible solo en home (PageLayout aplica conditional render SSR-gated).
 * Click → lenis.scrollTo(0) vía registerFlorPersistente() en scroll-system.ts.
 * Rotation scrub global → registrada por registerFlorPersistente en scroll-system.ts.
 *
 * ADR-016: la flor NO se renderiza en manifiesto ni contacto (ausencia total del DOM,
 *           no display:none). El gate es la prop `page` en PageLayout.
 *
 * BrandMark props: size acepta número (px), variant 'mono' para color via currentColor.
 * Decisión: se usa variant="mono" con CSS color: var(--color-teal) en el botón.
 */
import BrandMark from '@/components/astro/ui/BrandMark.astro'
---

<aside data-flor-persistente class="flor-persistente">
  <button type="button" data-flor-trigger aria-label="Volver al inicio">
    <BrandMark size={48} variant="mono" />
  </button>
</aside>

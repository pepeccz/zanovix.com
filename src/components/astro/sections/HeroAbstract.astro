---
/**
 * HeroAbstract.astro — Hero con SVG inline "red de nodos engineering"
 *
 * Estructura semántica:
 *   - Eyebrow mono uppercase
 *   - H1 serif weight 500 (texto principal)
 *   - Lede sans weight 400
 *   - SVG inline: red abstracta de nodos + conexiones (lado derecho en md+)
 *
 * El SVG contiene paths e IDs nombrados para que HeroChoreography.ts
 * los seleccione y anime individualmente.
 *
 * La coreografía de entrada (1.5s) vive en src/lib/motion/hero-choreography.ts
 * importada vía <script> al final de este componente.
 *
 * REQ-HC-1: SVG abstracto, nodos + conexiones, brand canon ink/teal/paper.
 * REQ-HC-2: Entrance ~1.5s, secuencia narrativa (texto → paths → nodos).
 * REQ-HC-3: reduced-motion → todo visible en estado final, sin animación.
 * REQ-HC-4: ScrollTrigger scrub continuation sin pin (ADR-004).
 * REQ-HC-5: Un solo componente de orquestación hero.
 *
 * Brand canon: ink #1F2A26, teal #3BAA8C, paper #F4F1EA.
 * NO el isotipo de 8 pétalos. NO chips, robots, cerebros literales.
 */
---

<section
  id="hero"
  aria-label="Hero — Zanovix IA aplicada a empresas"
  style="
    padding-top: var(--spacing-hero-y, clamp(3.5rem, 5vw + 2rem, 8rem));
    padding-bottom: var(--spacing-hero-y, clamp(3.5rem, 5vw + 2rem, 8rem));
    padding-left: var(--spacing-section-x);
    padding-right: var(--spacing-section-x);
    max-width: var(--container-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  "
>
  <!-- ── Texto hero ─────────────────────────────────────────────── -->
  <div
    id="hero-text"
    style="grid-column: 1; z-index: 2; max-width: 52ch;"
  >
    <!-- Eyebrow — mono uppercase como en DemoSection -->
    <p
      id="hero-eyebrow"
      style="
        font-family: var(--font-mono);
        font-size: var(--text-eyebrow);
        color: var(--color-teal);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.25rem;
        opacity: 0;
      "
    >
      IA aplicada a empresas
    </p>

    <!-- H1 serif weight 500 — clamp de --text-h1 -->
    <h1
      id="hero-headline"
      aria-label="Sistemas que trabajan. Resultados que se miden."
      style="
        font-family: var(--font-serif);
        font-size: var(--text-h1);
        font-weight: 500;
        line-height: 1.05;
        color: var(--color-ink);
        margin-bottom: 1.5rem;
        opacity: 0;
      "
    >
      Sistemas que trabajan.<br />
      Resultados que se miden.
    </h1>

    <!-- Lede sans weight 400 -->
    <p
      id="hero-lede"
      style="
        font-family: var(--font-sans);
        font-size: var(--text-lede);
        font-weight: 400;
        color: var(--ink-soft);
        line-height: 1.65;
        max-width: 46ch;
        margin-bottom: 0;
        opacity: 0;
      "
    >
      Implantamos inteligencia artificial en empresas reales.
      Sin hype, sin promesas vacías — solo sistemas que funcionan
      y ahorro documentado desde el primer trimestre.
    </p>
  </div>

  <!-- ── SVG Red de nodos engineering ──────────────────────────── -->
  <!--
    Composición abstracta: 8 nodos + 7 conexiones (edges) + grid guía sutil.
    Metáfora: piezas dispersas (procesos/datos) que se conectan en un sistema.
    REQ-HC-1: NO isotipo. Solo nodos geométricos abstractos.
    Brand canon: ink stroke, teal para nodo central destacado.
  -->
  <div
    id="hero-svg-wrapper"
    style="
      display: flex;
      justify-content: center;
      align-items: center;
      opacity: 0;
    "
  >
    <svg
      id="hero-svg"
      viewBox="0 0 680 520"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Diagrama abstracto de una red de nodos interconectados que representa la integración de sistemas empresariales mediante inteligencia artificial"
      style="width: 100%; height: auto; max-width: 640px; display: block;"
      fill="none"
    >
      <!-- ── Grid guía blueprint (decorativo, opacity muy baja) ── -->
      <g id="grid" opacity="0.06" stroke="#1F2A26" stroke-width="0.5">
        <!-- Horizontales -->
        <line x1="0" y1="80"  x2="680" y2="80" />
        <line x1="0" y1="160" x2="680" y2="160" />
        <line x1="0" y1="260" x2="680" y2="260" />
        <line x1="0" y1="360" x2="680" y2="360" />
        <line x1="0" y1="440" x2="680" y2="440" />
        <!-- Verticales -->
        <line x1="110" y1="0" x2="110" y2="520" />
        <line x1="260" y1="0" x2="260" y2="520" />
        <line x1="420" y1="0" x2="420" y2="520" />
        <line x1="570" y1="0" x2="570" y2="520" />
      </g>

      <!-- ── Connections (edges entre nodos) ─────────────────── -->
      <!--
        6 paths con curvas Bezier suaves — stroke ink 1px.
        IDs: c1–c6 para animación individual con drawPath.
      -->
      <g id="connections" stroke="#1F2A26" stroke-width="1.2" stroke-linecap="round">
        <!-- c1: n1 (110,160) → n3 (260,260) -->
        <path id="c1" d="M110,160 C165,160 205,260 260,260" />
        <!-- c2: n3 (260,260) → n5-central (420,260) -->
        <path id="c2" d="M260,260 C320,260 360,260 420,260" />
        <!-- c3: n2 (110,360) → n3 (260,260) -->
        <path id="c3" d="M110,360 C165,360 205,260 260,260" />
        <!-- c4: n5-central (420,260) → n6 (570,160) -->
        <path id="c4" d="M420,260 C480,260 520,160 570,160" />
        <!-- c5: n5-central (420,260) → n7 (570,360) -->
        <path id="c5" d="M420,260 C480,260 520,360 570,360" />
        <!-- c6: n4 (260,80) → n5-central (420,260) — conexión diagonal -->
        <path id="c6" d="M260,80 C310,80 390,180 420,260" opacity="0.6" />
        <!-- c7: n8 (420,440) → n5-central (420,260) — vertical sutil -->
        <path id="c7" d="M420,440 C420,420 420,300 420,260" opacity="0.5" />
      </g>

      <!-- ── Nodos ──────────────────────────────────────────── -->
      <!--
        Mix de círculos y diamantes para feel mechanical/engineering.
        IDs: n1–n8. n5 es el nodo central (teal).
      -->
      <g id="nodes">
        <!-- n1: círculo simple, izq-arriba -->
        <circle id="n1" cx="110" cy="160" r="8" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" />
        <!-- n2: círculo, izq-abajo -->
        <circle id="n2" cx="110" cy="360" r="8" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" />
        <!-- n3: diamante (rotación de cuadrado) — nodo intermedio -->
        <rect id="n3" x="247" y="247" width="26" height="26" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" transform="rotate(45, 260, 260)" />
        <!-- n4: círculo pequeño, arriba centro-izq -->
        <circle id="n4" cx="260" cy="80" r="6" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" opacity="0.7" />
        <!-- n5: NODO CENTRAL — teal, más grande, acento de la composición -->
        <circle id="n5" cx="420" cy="260" r="14" fill="#3BAA8C" stroke="#1F2A26" stroke-width="1.5" />
        <!-- n5-inner: punto interior teal oscuro para profundidad -->
        <circle id="n5-inner" cx="420" cy="260" r="5" fill="#F4F1EA" opacity="0.8" />
        <!-- n6: diamante, der-arriba -->
        <rect id="n6" x="558" y="148" width="24" height="24" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" transform="rotate(45, 570, 160)" />
        <!-- n7: círculo, der-abajo -->
        <circle id="n7" cx="570" cy="360" r="8" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" />
        <!-- n8: círculo pequeño, centro-abajo -->
        <circle id="n8" cx="420" cy="440" r="6" fill="#F4F1EA" stroke="#1F2A26" stroke-width="1.5" opacity="0.7" />
      </g>

      <!-- ── Labels técnicos mono ──────────────────────────── -->
      <!--
        2–3 micro-etiquetas en JetBrains Mono. Refuerzan tono engineering.
        IDs: lbl1–lbl3 para animación.
      -->
      <g id="labels" opacity="0" font-family="'JetBrains Mono', ui-monospace, monospace" font-size="9" fill="#1F2A26">
        <!-- Input label cerca de n1 -->
        <text id="lbl1" x="72" y="152" text-anchor="end" opacity="0.55">input</text>
        <!-- Process label cerca de n3 -->
        <text id="lbl2" x="242" y="240" text-anchor="end" font-size="8" opacity="0.5">proc</text>
        <!-- Output label cerca de n6 -->
        <text id="lbl3" x="598" y="152" opacity="0.55">output</text>
        <!-- Version tag cerca de n8 -->
        <text id="lbl4" x="432" y="448" font-size="8" opacity="0.45">v1.0</text>
      </g>

      <!-- ── Accent ring teal alrededor de n5 (pulse sutil post-entrada) ── -->
      <circle
        id="n5-ring"
        cx="420" cy="260" r="22"
        fill="none"
        stroke="#3BAA8C"
        stroke-width="1"
        opacity="0"
      />
    </svg>
  </div>
</section>

<style>
  /*
   * En md+ (≥768px): layout 2 columnas — texto izquierda, SVG derecha.
   * En mobile: columna única, SVG debajo del texto.
   * REQ-HC-1: SVG responsive.
   */
  @media (min-width: 768px) {
    #hero {
      grid-template-columns: 1fr 1fr !important;
    }

    #hero-text {
      max-width: 100% !important;
    }

    #hero-svg-wrapper {
      grid-column: 2;
      grid-row: 1;
    }
  }

  /* reduced-motion: mostrar todo en estado final, sin opacity 0 inicial */
  @media (prefers-reduced-motion: reduce) {
    #hero-eyebrow,
    #hero-headline,
    #hero-lede,
    #hero-svg-wrapper {
      opacity: 1 !important;
    }

    #labels {
      opacity: 1 !important;
    }

    #hero-svg [id^="c"] {
      stroke-dashoffset: 0 !important;
    }
  }
</style>

<!--
  HeroChoreography: coreografía GSAP entrance 1.5s + scroll continuation.
  Se importa como script module — Astro bundlea y ejecuta en cliente.
  No se usa revealStagger (bug latente flagged en verify-report-pr2).
-->
<script>
  import '../../../lib/motion/hero-choreography.ts'
</script>

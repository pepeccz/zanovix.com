---
/**
 * Cap1Hero.astro — Capítulo 1: Hero de la home
 *
 * Refactor de HeroAbstract.astro → estructura editorial sin SVG.
 * La tipografía Cormorant Garamond ES la pieza visual.
 *
 * IDs preservados para compatibilidad con hero-choreography.ts:
 *   #hero, #hero-eyebrow, #hero-headline, #hero-lede, #hero-svg-wrapper
 *
 * data-chapter="1" para targeting de scroll-system.ts.
 * Sin imports GSAP/ScrollTrigger inline — la coreografía vive en
 * hero-choreography.ts importada vía <script>.
 *
 * Copy canonical: copy-override #6015 (frame: estudio de IA).
 */
---

<section
  id="hero"
  data-chapter="1"
  aria-label="Zanovix: IA aplicada a empresas"
  class="chapter"
  style="
    position: relative;
    padding-top: var(--spacing-hero-y);
    padding-bottom: var(--spacing-hero-y);
    padding-left: var(--spacing-section-x);
    padding-right: var(--spacing-section-x);
    max-width: var(--container-wide);
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  "
>
  <!--
    #hero-text: contenedor del grupo de texto.
    hero-choreography.ts usa este ID para el parallax de scroll (y offset suave).
    Envuelve eyebrow + headline + lede para que el parallax mueva el grupo completo.
  -->
  <div id="hero-text">
    <!-- Eyebrow mono -->
    <p
      id="hero-eyebrow"
      style="
        font-family: var(--font-mono);
        font-size: var(--text-eyebrow);
        color: var(--ink-mute-strong);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
        opacity: 0;
      "
    >
      // IA aplicada
    </p>

    <!-- H1 display Cormorant Garamond -->
    <h1
      id="hero-headline"
      class="display-cormorant"
      style="
        max-width: 18ch;
        margin-bottom: 2rem;
        opacity: 0;
        overflow-wrap: break-word;
        text-wrap: balance;
      "
    >
      La búsqueda cambió.
    </h1>

    <!-- Sub-línea Newsreader -->
    <p
      id="hero-lede"
      style="
        font-family: var(--font-serif);
        font-size: clamp(1.0625rem, 0.4vw + 0.97rem, 1.5rem);
        font-weight: 400;
        color: var(--ink-soft);
        line-height: 1.6;
        max-width: 48ch;
        margin-bottom: 2rem;
        opacity: 0;
      "
    >
      Tus clientes ya le preguntan a ChatGPT, no solo a Google. Si ahí no apareces, para ellos no existes, y ni te enteras. Lo primero que hacemos es ponerte donde te buscan. Lo segundo, que dejes de contestar a mano lo de siempre.
    </p>

    <!-- Brand sign-off: low-hierarchy closing mark, static (no animation ID) -->
    <p
      class="hero-signoff"
      style="
        font-family: var(--font-mono);
        font-size: var(--text-eyebrow);
        color: var(--ink-mute-strong);
        letter-spacing: 0.08em;
      "
    >
      Ingeniería pausada con IA
    </p>
  </div>

  <!--
    #hero-svg-wrapper: SVG flor inline con IDs para bloom scrub-driven.
    position: absolute lateral-derecho en desktop (ADR-013). No altera el
    flujo tipográfico ni la altura del H1.

    SYNC: geometría pétalo idéntica a BrandMark.astro y /public/isotipo-mask.svg.
    Cualquier cambio en la forma del pétalo debe replicarse en los 3 archivos.
  -->
  <div id="hero-svg-wrapper" class="flor-hero-wrapper" aria-hidden="true">
    <svg
      data-flor-bloom-root
      viewBox="0 0 100 100"
      xmlns="http://www.w3.org/2000/svg"
      width="100%"
      height="100%"
      fill="none"
    >
      <!--
        Rotación radial en el atributo transform del SVG (no en CSS).
        GSAP solo anima opacity — así no toca la rotación.
      -->
      <path id="petal-0" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-1" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(45 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-2" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(90 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-3" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(135 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-4" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(180 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-5" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(225 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-6" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(270 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <path id="petal-7" d="M 50,30 Q 38,17 50,4 Q 62,17 50,30 Z" transform="rotate(315 50 50)"
        fill="var(--color-teal)" stroke="var(--color-ink)" stroke-width="3.2" stroke-linejoin="round"
        style="opacity:0;" />
      <circle
        id="petal-center"
        cx="50" cy="50" r="5.5"
        fill="var(--color-ink)"
        style="opacity:0;" />
    </svg>
  </div>
</section>

<style>
  /* Reduced-motion: mostrar todo en estado final */
  @media (prefers-reduced-motion: reduce) {
    #hero-eyebrow,
    #hero-headline,
    #hero-lede {
      opacity: 1 !important;
    }

    /* Flor wrapper: asegurar visibilidad (fix: opacity:0 en .flor-hero-wrapper
       no puede ocultar a sus hijos cuando estos son forzados a opacity:1) */
    .flor-hero-wrapper {
      opacity: 1 !important;
    }

    /* Flor bloom: estado final en reduced-motion */
    .flor-hero-wrapper [id^="petal-"],
    .flor-hero-wrapper #petal-center {
      opacity: 1 !important;
    }
  }

  /* Desktop: flor absolute lateral derecho — sin interferir con flujo del H1 */
  /* La sección tiene position: relative via style inline */
  .flor-hero-wrapper {
    position: absolute;
    right: 6%;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(220px, 30vw, 420px);
    aspect-ratio: 1 / 1;
    pointer-events: none;
    z-index: 1;
    /* opacity arrancará en 0; hero-choreography.ts la lleva a 1 en t=0.0 */
    opacity: 0;
  }

  /* Mobile: flujo normal encima del texto */
  @media (max-width: 767px) {
    .flor-hero-wrapper {
      position: relative;
      right: auto;
      top: auto;
      transform: none;
      margin: 0 auto 2rem;
      width: 200px;
    }
  }
</style>

<script>
  import '../../../../lib/motion/hero-choreography.ts'
</script>

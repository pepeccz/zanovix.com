---
/**
 * Cap7Contacto.astro — Capítulo 7: CTA final + mini-footer
 *
 * H2 Newsreader ~64px. CTA mailto en JetBrains Mono.
 * Mini-footer con BrandMark isotipo + copyright. NO el footer del PageLayout.
 *
 * Copy canonical: copy-override #6015 (Málaga, hola@zanovix.com).
 * Sin motion inline.
 */

import Eyebrow from '../../ui/Eyebrow.astro'
import BrandMark from '../../ui/BrandMark.astro'
---

<section
  data-chapter="7"
  id="cap-7"
  class="chapter"
  style="
    padding-top: var(--spacing-section-y);
    padding-bottom: var(--spacing-section-y);
    padding-left: var(--spacing-section-x);
    padding-right: var(--spacing-section-x);
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  "
>
  <div style="max-width: var(--container-wide); margin: 0 auto; width: 100%;">
    <!-- Eyebrow -->
    <Eyebrow class="mb-8">// conversación</Eyebrow>

    <!-- H2 -->
    <h2
      style="
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4vw + 0.5rem, 4rem);
        font-weight: 500;
        line-height: 1.1;
        color: var(--color-ink);
        max-width: 28ch;
        margin-bottom: clamp(2.5rem, 4vw, 4rem);
      "
    >
      Si tienes un proceso que merece criterio, hablemos.
    </h2>

    <!-- CTA mailto -->
    <a
      href="mailto:hola@zanovix.com"
      style="
        font-family: var(--font-mono);
        font-size: clamp(1.25rem, 2vw + 0.5rem, 2rem);
        font-weight: 400;
        color: var(--color-ink);
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 0.25em;
        text-decoration-color: var(--color-teal);
        letter-spacing: -0.01em;
        display: inline-block;
        margin-bottom: clamp(4rem, 8vw, 8rem);
      "
    >
      hola@zanovix.com
    </a>

    <!-- Mini-footer interno — NO el footer del PageLayout (eso es PR 3) -->
    <footer
      style="
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-rule);
      "
    >
      <BrandMark size={32} />
      <p
        style="
          font-family: var(--font-sans);
          font-size: 0.875rem;
          font-weight: 400;
          color: var(--ink-mute);
        "
      >
        © 2026 Zanovix · Málaga
      </p>
    </footer>
  </div>
</section>

---
/**
 * Cap3QueHacemos.astro — Capítulo 3: Qué hacemos — 4 disciplinas
 *
 * Grid 2x2 con numeración JetBrains Mono, títulos Newsreader, cuerpo Inter.
 * Clase .reveal en cada item para IntersectionObserver stagger.
 *
 * Sin motion inline. Copy canonical: copy-override #6015.
 */

import Eyebrow from '../../ui/Eyebrow.astro'
---

<section
  data-chapter="3"
  id="cap-3"
  class="chapter"
  style="
    padding-top: var(--spacing-section-y);
    padding-bottom: var(--spacing-section-y);
    padding-left: var(--spacing-section-x);
    padding-right: var(--spacing-section-x);
  "
>
  <div style="max-width: var(--container-wide); margin: 0 auto;">
    <!-- Eyebrow -->
    <Eyebrow class="mb-6" style="color: var(--color-teal);">// método</Eyebrow>

    <!-- H2 -->
    <h2
      style="
        font-family: var(--font-serif);
        font-size: var(--text-h2);
        font-weight: 500;
        line-height: 1.15;
        color: var(--color-ink);
        max-width: 32ch;
        margin-bottom: clamp(2.5rem, 4vw, 4rem);
      "
    >
      Cuatro disciplinas. Una manera de trabajar.
    </h2>

    <!-- Grid 2x2 -->
    <div
      style="
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      "
      class="md:grid-cols-2"
    >
      <!-- 01 — Diagnóstico -->
      <div class="reveal" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <span
          style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--ink-mute);
            letter-spacing: 0.05em;
          "
        >01</span>
        <h3
          style="
            font-family: var(--font-serif);
            font-size: var(--text-h3);
            font-weight: 500;
            color: var(--color-ink);
            line-height: 1.2;
          "
        >Diagnóstico</h3>
        <p
          style="
            font-family: var(--font-sans);
            font-size: var(--text-body);
            font-weight: 400;
            color: var(--ink-soft);
            line-height: 1.65;
          "
        >
          Antes de aplicar IA, entendemos el dominio, el equipo y la fricción real.
        </p>
      </div>

      <!-- 02 — Arquitectura IA -->
      <div class="reveal" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <span
          style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--ink-mute);
            letter-spacing: 0.05em;
          "
        >02</span>
        <h3
          style="
            font-family: var(--font-serif);
            font-size: var(--text-h3);
            font-weight: 500;
            color: var(--color-ink);
            line-height: 1.2;
          "
        >Arquitectura IA</h3>
        <p
          style="
            font-family: var(--font-sans);
            font-size: var(--text-body);
            font-weight: 400;
            color: var(--ink-soft);
            line-height: 1.65;
          "
        >
          Diseñamos sistemas de IA que sobreviven al cambio. Patrones primero, modelos después.
        </p>
      </div>

      <!-- 03 — Asistentes a medida -->
      <div class="reveal" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <span
          style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--ink-mute);
            letter-spacing: 0.05em;
          "
        >03</span>
        <h3
          style="
            font-family: var(--font-serif);
            font-size: var(--text-h3);
            font-weight: 500;
            color: var(--color-ink);
            line-height: 1.2;
          "
        >Asistentes a medida</h3>
        <p
          style="
            font-family: var(--font-sans);
            font-size: var(--text-body);
            font-weight: 400;
            color: var(--ink-soft);
            line-height: 1.65;
          "
        >
          Asistentes y harnesses para procesos reales. Sin productos enlatados.
        </p>
      </div>

      <!-- 04 — Acompañamiento -->
      <div class="reveal" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <span
          style="
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--ink-mute);
            letter-spacing: 0.05em;
          "
        >04</span>
        <h3
          style="
            font-family: var(--font-serif);
            font-size: var(--text-h3);
            font-weight: 500;
            color: var(--color-ink);
            line-height: 1.2;
          "
        >Acompañamiento</h3>
        <p
          style="
            font-family: var(--font-sans);
            font-size: var(--text-body);
            font-weight: 400;
            color: var(--ink-soft);
            line-height: 1.65;
          "
        >
          Quedamos cerca del equipo hasta que el sistema se sostiene solo.
        </p>
      </div>
    </div>
  </div>
</section>

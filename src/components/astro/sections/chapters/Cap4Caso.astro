---
/**
 * Cap4Caso.astro — Capítulo 4: Caso destacado
 *
 * .section--inverted la añade scroll-system.ts via registerCap4PaletteInversion().
 * NO se hardcodea en markup. El root debe permitir esa clase aplicada.
 *
 * Counter animado eliminado: la cifra "80.000 €" no era atribuible ni verificable.
 * Copy canonical: copy-override #6015 (revisado 2026-06-17).
 */

import Eyebrow from '../../ui/Eyebrow.astro'
---

<section
  data-chapter="4"
  data-cap4-root
  id="cap-4"
  class="chapter"
  style="
    padding-top: clamp(6rem, 10vw, 12rem);
    padding-bottom: clamp(6rem, 10vw, 12rem);
    padding-left: var(--spacing-section-x);
    padding-right: var(--spacing-section-x);
    transition: background 240ms ease, color 240ms ease;
  "
>
  <div style="max-width: var(--container-wide); margin: 0 auto;">
    <!-- Eyebrow -->
    <Eyebrow class="mb-6">// caso</Eyebrow>

    <!-- H2 -->
    <h2
      style="
        font-family: var(--font-serif);
        font-size: clamp(1.75rem, 3vw + 0.5rem, 3rem);
        font-weight: 500;
        line-height: 1.15;
        color: inherit;
        max-width: 36ch;
        margin-bottom: clamp(2.5rem, 4vw, 4rem);
      "
    >
      Un asistente. Un proceso medido. Un resultado verificable.
    </h2>

    <!-- INTERINO: pendiente re-alineación narrativa Cap4 (caso SmartCatering con datos cuando exista re-baseline GEO) -->

    <!-- Body -->
    <p
      style="
        font-family: var(--font-serif);
        font-size: var(--text-lede);
        font-weight: 400;
        line-height: 1.65;
        color: inherit;
        max-width: 54ch;
        opacity: 0.85;
        margin-bottom: clamp(2rem, 3vw, 3rem);
      "
    >
      Rediseño web completo, saneamiento técnico y GEO en ejecución. Trabajo real con proceso medido: cada fase documentada, cada decisión justificada.
    </p>

    <p
      style="
        font-family: var(--font-sans);
        font-size: var(--text-body);
        font-weight: 400;
        line-height: 1.6;
        max-width: 54ch;
      "
    >
      El equipo del cliente conserva el control operativo. Nosotros aportamos la estructura técnica y la responsabilidad de ejecución.
    </p>
  </div>
</section>

---
/**
 * PageLayout.astro — nav + footer con BrandMark
 *
 * Envuelve Base.astro (HTML shell + motion) añadiendo la estructura
 * semántica de página: skip-link > header > main > footer.
 *
 * Jerarquía: Base.astro → PageLayout.astro → páginas
 *
 * REQ-LS-2: header con BrandMark + nav minimal + footer con BrandMark.
 * REQ-LS-3: skip-link accesible.
 * REQ-LS-4: estructura semántica header > main#main-content > footer.
 */

import Base from './Base.astro'
import BrandMark from '../components/astro/ui/BrandMark.astro'

// Preload Cormorant Garamond Variable woff2 (latin, wght axis, no italic)
// Path: @fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-normal.woff2
// Si el path no resuelve en una versión futura del package, comentar la línea
// y documentar aquí: font-display:swap (fontsource default) absorbe el FOUT.
import cormorantWoff2 from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-normal.woff2?url'

interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props
---

<Base title={title} description={description}>
  <link
    rel="preload"
    as="font"
    type="font/woff2"
    href={cormorantWoff2}
    crossorigin
    slot="head"
  />
  <!-- Skip link de accesibilidad (visible al tabular) -->
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <header class="border-b border-[var(--color-rule)] py-4">
    <div class="mx-auto flex max-w-[var(--container-wide)] items-center justify-between px-[var(--spacing-section-x)]">
      <a
        href="/"
        class="flex items-center gap-3 text-[var(--color-ink)] no-underline"
        aria-label="Zanovix — Inicio"
      >
        <BrandMark size={32} />
        <span class="font-[var(--font-mono)] text-[var(--text-eyebrow)] uppercase tracking-widest">
          Zanovix
        </span>
      </a>

      <!-- Navegación minimal v1 — placeholder para futuras secciones -->
      <nav aria-label="Navegación principal">
        <ul class="flex list-none gap-6 m-0 p-0">
          <!-- PR futuro añadirá links reales -->
        </ul>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="border-t border-[var(--color-rule)] py-8 mt-[var(--spacing-section-y)]">
    <div class="mx-auto flex max-w-[var(--container-wide)] items-center justify-between px-[var(--spacing-section-x)]">
      <a
        href="/"
        class="flex items-center gap-3 text-[var(--color-ink)] no-underline"
        aria-label="Zanovix — Inicio"
      >
        <BrandMark size={24} />
        <span class="font-[var(--font-mono)] text-[var(--text-eyebrow)] uppercase tracking-widest">
          Zanovix
        </span>
      </a>

      <p class="text-[var(--text-eyebrow)] text-[var(--ink-mute)] font-[var(--font-mono)]">
        &copy; {new Date().getFullYear()} Zanovix
      </p>
    </div>
  </footer>
</Base>

---
/**
 * PageLayout.astro — nav + footer con BrandMark
 *
 * Envuelve Base.astro (HTML shell + motion) añadiendo la estructura
 * semántica de página: skip-link > header > main > footer.
 *
 * Jerarquía: Base.astro → PageLayout.astro → páginas
 *
 * REQ-LS-2: header con BrandMark + nav minimal + footer con BrandMark.
 * REQ-LS-3: skip-link accesible.
 * REQ-LS-4: estructura semántica header > main#main-content > footer.
 *
 * Nav principal (lean, ruta de conversión): Servicios · Casos · Metodología ·
 * Sobre · Contacto.
 * Footer (secundarios): Manifiesto · Privacidad · GitHub + © 2026 Zanovix.
 */

import Base from './Base.astro'
import SiteNav from '../components/astro/ui/SiteNav.astro'
import ContactDialog from '../components/react/ContactDialog.tsx'
import Assistant from '../components/react/Assistant.tsx'

interface Props {
  title?: string
  description?: string
  /** Identificador de pagina. Propaga data-page al <body> via Base.astro.
   *  Valores canonicos: 'home' | 'manifiesto' | 'contacto'. Default: ''.
   */
  page?: string
  /** Compat: prop historica del dock del Companion (ya retirado). Se acepta
   *  para no romper paginas que aun la pasan; no tiene efecto. */
  showCompanion?: boolean
}

const { title, description, page = '' } = Astro.props
---

<Base title={title} description={description} page={page}>
  <!-- Skip link de accesibilidad (visible al tabular) -->
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <!-- Nav de producción: isla flotante (píldora) con floración por dirección de
       scroll, isotipo real como flor-pivote y subrayado de página activa. Trae
       su propio overlay móvil. Ver SiteNav.astro. -->
  <SiteNav />

  <main id="main-content" class="page-main">
    <slot />
  </main>

  <footer class="border-t border-[var(--color-rule)] py-8 mt-[var(--spacing-section-y)]">
    <div
      class="mx-auto max-w-[var(--container-wide)] px-[var(--spacing-section-x)]"
      style="display: flex; flex-direction: column; gap: 1.25rem;"
    >
      <!-- Fila superior: isotipo + nav inline -->
      <div class="flex items-center justify-between flex-wrap gap-4">
        <a
          href="/"
          class="flex items-center gap-3 text-[var(--color-ink)] no-underline"
          aria-label="Zanovix · Inicio"
        >
          <img src="/isotipo.svg" alt="" width="32" height="32" />
        </a>

        <nav aria-label="Navegación de pie de página">
          <ul class="flex list-none gap-6 m-0 p-0 flex-wrap">
            <li>
              <a
                href="/manifiesto"
                class="font-[var(--font-brand)] text-[var(--text-eyebrow)] text-[var(--ink-mute-strong)] no-underline uppercase tracking-widest hover:text-[var(--color-ink)] transition-colors duration-200"
              >
                Manifiesto
              </a>
            </li>
            <li>
              <a
                href="/privacidad"
                class="font-[var(--font-brand)] text-[var(--text-eyebrow)] text-[var(--ink-mute-strong)] no-underline uppercase tracking-widest hover:text-[var(--color-ink)] transition-colors duration-200"
              >
                Privacidad
              </a>
            </li>
            <li>
              <a
                href="https://github.com/pepeccz"
                target="_blank"
                rel="noopener noreferrer"
                class="font-[var(--font-brand)] text-[var(--text-eyebrow)] text-[var(--ink-mute-strong)] no-underline uppercase tracking-widest hover:text-[var(--color-ink)] transition-colors duration-200"
                aria-label="GitHub de Zanovix (abre en nueva pestaña)"
              >
                GitHub
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Línea final: copyright -->
      <p class="text-[var(--text-eyebrow)] text-[var(--ink-mute-strong)] font-[var(--font-brand)]">
        &copy; 2026 Zanovix · Málaga
      </p>
    </div>
  </footer>

  {/*
    Asistente global discreto. Montado UNA vez aqui para estar disponible en
    todas las paginas. client:idle: no es critico para el primer paint y solo
    reacciona a una accion explicita del visitante (NUNCA se abre solo). El
    lanzador es position:fixed y discreto; al abrir muestra un panel calmado.
    Reemplaza al dock y al hero del antiguo Companion.
  */}
  <Assistant client:idle />

  {/*
    Dialogo de captacion en contexto. Montado UNA vez aqui para estar
    disponible en todas las paginas. client:idle: no es critico para el
    primer paint y solo reacciona a una accion explicita del visitante.
    Escucha el CustomEvent global `zx:open-contact` (ver script delegado),
    que dispara tanto un CTA [data-open-contact] como el handoff del asistente.
  */}
  <ContactDialog client:idle />

  <script is:inline>
    // Captacion como dialogo en contexto: progressive enhancement.
    // Listener delegado en clicks de [data-open-contact]. Con JS, intercepta
    // el CTA, evita la navegacion y dispara el evento global que abre el
    // <dialog>. SIN JS, el CTA sigue siendo <a href="/contacto"> y navega.
    // El contexto (nombre/sector/zona/veredicto/origen) viaja en data-* y/o
    // en el detail que pueda inyectar otra isla (p.ej. el simulador GEO).
    (function setupContactDialogTriggers() {
      document.addEventListener('click', function (e) {
        var target = e.target;
        if (!target || typeof target.closest !== 'function') return;
        var trigger = target.closest('[data-open-contact]');
        if (!trigger) return;
        // Respeta abrir en nueva pestana / con modificadores.
        if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) {
          return;
        }
        e.preventDefault();
        var d = trigger.dataset || {};
        window.dispatchEvent(
          new CustomEvent('zx:open-contact', {
            detail: {
              name: d.contactName || undefined,
              sector: d.contactSector || undefined,
              zone: d.contactZone || undefined,
              geoVerdict: d.contactVerdict || undefined,
              origin: d.contactOrigin || trigger.getAttribute('href') || undefined,
              trigger: trigger,
            },
          })
        );
      });
    })();
  </script>

  <style>
    /* ── Clearance bajo la isla flotante (nav fixed) ─────────────────────
     * El nav nuevo (SiteNav) es una píldora position:fixed: no ocupa altura de
     * layout como el header sticky anterior. Para que el primer bloque de cada
     * página no quede tapado, restauramos arriba el espacio que el header viejo
     * aportaba (~64px). El padding-top se SUMA al espaciado propio del hero
     * (--spacing-hero-y), por lo que no rompe heros con su propio aire. */
    .page-main {
      padding-top: 4rem;
    }
  </style>
</Base>

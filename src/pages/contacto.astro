---
/**
 * contacto.astro — pagina de contacto de Zanovix
 *
 * El formulario es ahora la via principal: capta el lead junto con el
 * contexto que el compañero ya infirio (sector/dolor/urgencia desde
 * sessionStorage, prellenado en cliente). Manda el lead por email
 * transaccional via /api/lead.
 *
 * El mailto se conserva SOLO como linea secundaria de fallback honesto
 * (dentro del propio formulario y aqui abajo), nunca como CTA primario.
 *
 * Estructura:
 *   - Eyebrow // conversacion
 *   - H1: Hablemos.
 *   - Sub pausado
 *   - LeadForm (isla React, client:load): formulario real con prefill
 *   - Mini-info: Malaga · ES
 */
import PageLayout from '../layouts/PageLayout.astro'
import LeadForm from '../components/react/LeadForm.tsx'
---

<PageLayout
  title="Contacto · Zanovix"
  description="Cuentanos tu caso en un minuto. Si ya has hablado con el asistente, llegas con el contexto a mano. Respondemos en menos de 24h habiles."
  page="contacto"
  showCompanion={false}
>
  <section
    id="contacto-form"
    class="ctc"
    aria-labelledby="contacto-title"
  >
    <div class="ctc__inner">
      <aside class="ctc__aside" data-reveal>
        <p class="ctc__eyebrow">Conversación</p>
        <h1 id="contacto-title" class="display ctc__title">Hablemos.</h1>
        <p class="ctc__lede">
          Cuéntanos tu caso en un minuto. Si ya has hablado con el asistente, llegas
          con el contexto a mano y lo puedes corregir. Respondemos en menos de 24h
          hábiles.
        </p>
      </aside>

      <div data-reveal data-reveal-i="1">
        <LeadForm client:load />
        <p class="ctc__meta">Málaga · ES</p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .ctc {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--spacing-hero-y) var(--spacing-section-x) var(--spacing-section-y);
  }
  .ctc__inner {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 880px) {
    .ctc__inner {
      grid-template-columns: 0.9fr 1.1fr;
      gap: clamp(2.5rem, 5vw, 5rem);
      align-items: start;
    }
    .ctc__aside {
      position: sticky;
      top: 6rem;
      align-self: start;
    }
  }
  .ctc__eyebrow {
    font-family: var(--font-brand);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-mute-strong);
    margin: 0 0 0.75rem;
    padding-left: 1.1rem;
    position: relative;
  }
  .ctc__eyebrow::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-teal-deep);
  }
  .ctc__title {
    font-size: var(--text-display);
    color: var(--color-ink);
    margin: 0 0 1rem;
  }
  .ctc__lede {
    font-size: var(--text-lede);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 46ch;
    margin: 0;
  }
  .ctc__meta {
    font-family: var(--font-brand);
    font-size: var(--text-eyebrow);
    color: var(--ink-mute);
    letter-spacing: 0.08em;
    margin-top: clamp(2rem, 4vw, 3rem);
  }
</style>

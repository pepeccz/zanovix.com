---
/**
 * contacto.astro — Página de contacto de Zanovix
 *
 * Sin formulario backend, sin captcha, sin calendly.
 * Solo el mailto directo — criterio editorial: la conversación empieza con un email.
 *
 * Estructura:
 *   - Eyebrow // conversación
 *   - H1 Newsreader font-medium: Hablemos.
 *   - Sub Inter ink-mute: texto pausado
 *   - CTA mailto JetBrains Mono con teal underline
 *   - Mini-info: Málaga · ES
 */
import PageLayout from '../layouts/PageLayout.astro'
---

<PageLayout
  title="Contacto · Zanovix"
  description="Si tienes un proceso que merece criterio, escríbenos. Respondemos en menos de 24h hábiles."
>
  <section
    style="
      max-width: var(--container-wide);
      margin: 0 auto;
      padding: var(--spacing-section-y) var(--spacing-section-x);
      min-height: 70vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    "
  >
    <!-- Eyebrow -->
    <p
      style="
        font-family: var(--font-mono);
        font-size: var(--text-eyebrow);
        color: var(--color-teal);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 2rem;
      "
    >
      // conversación
    </p>

    <!-- H1 Newsreader font-medium -->
    <h1
      style="
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: clamp(3rem, 6vw + 1rem, 4.5rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--color-ink);
        margin-bottom: 1.75rem;
        max-width: 16ch;
      "
    >
      Hablemos.
    </h1>

    <!-- Sub Newsreader ink-soft -->
    <p
      style="
        font-family: var(--font-serif);
        font-size: clamp(1.0625rem, 0.4vw + 0.97rem, 1.3125rem);
        font-weight: 400;
        color: var(--ink-soft);
        line-height: 1.65;
        max-width: 46ch;
        margin-bottom: 3rem;
      "
    >
      Si tienes un proceso que merece criterio, escríbenos directamente.
      Respondemos en menos de 24h hábiles.
    </p>

    <!-- CTA mailto — JetBrains Mono con teal underline -->
    <a
      href="mailto:hola@zanovix.com"
      style="
        font-family: var(--font-mono);
        font-size: clamp(1.5rem, 3vw + 0.5rem, 3rem);
        font-weight: 400;
        color: var(--color-ink);
        text-decoration: underline;
        text-decoration-color: var(--color-teal);
        text-decoration-thickness: 2px;
        text-underline-offset: 0.35em;
        display: inline-block;
        margin-bottom: 2.5rem;
        transition: color 200ms ease;
      "
    >
      hola@zanovix.com
    </a>

    <!-- Mini-info -->
    <p
      style="
        font-family: var(--font-mono);
        font-size: var(--text-eyebrow);
        color: var(--ink-mute);
        letter-spacing: 0.05em;
      "
    >
      Málaga · ES
    </p>
  </section>
</PageLayout>

<style>
  /* Hover del mailto: color teal al pasar el ratón */
  a[href^="mailto"]:hover {
    color: var(--color-teal);
  }
</style>

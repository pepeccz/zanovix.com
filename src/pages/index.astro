---
/**
 * index.astro — home page
 *
 * Compone los 7 capítulos del scroll editorial en orden.
 * Sin lógica de motion inline — toda la orquestación vive en
 * scroll-system.ts (bootstrap) y hero-choreography.ts (Cap 1).
 *
 * PR 2 de 3: chapters 1-7 implementados. Motion ya wired en PR 1.
 */

import PageLayout from '../layouts/PageLayout.astro'
import Cap1Hero from '../components/astro/sections/chapters/Cap1Hero.astro'
import CapVideoMask from '../components/astro/sections/chapters/CapVideoMask.astro'
import Cap2Declaracion from '../components/astro/sections/chapters/Cap2Declaracion.astro'
import Cap3QueHacemos from '../components/astro/sections/chapters/Cap3QueHacemos.astro'
import Cap4Caso from '../components/astro/sections/chapters/Cap4Caso.astro'
import Cap5Como from '../components/astro/sections/chapters/Cap5Como.astro'
import Cap6Manifiesto from '../components/astro/sections/chapters/Cap6Manifiesto.astro'
import CapAsistente from '../components/astro/sections/chapters/CapAsistente.astro'
import Cap7Contacto from '../components/astro/sections/chapters/Cap7Contacto.astro'
---

<PageLayout
  title="Zanovix — IA aplicada a empresas"
  description="Soluciones de inteligencia artificial para empresas. Resultados medibles, implementación ética."
  page="home"
>
  <Cap1Hero />
  <CapVideoMask />
  <Cap2Declaracion />
  <Cap3QueHacemos />
  <Cap4Caso />
  <Cap5Como />
  <Cap6Manifiesto />
  <CapAsistente />
  <Cap7Contacto />
</PageLayout>

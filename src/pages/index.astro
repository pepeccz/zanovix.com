---
/**
 * index.astro — home (rediseño "herramienta honesta cálida")
 *
 * Eje: el mensaje firmado en una frase + CTAs claros. El demo incrustado
 * (Companion hero) se retiró: la radiografia GEO vive ahora en su sitio,
 * la pagina de servicio GEO, donde pide el nombre real del negocio. El hero
 * se sostiene solo con el mensaje y una escena visual sobria (no un demo)
 * que dramatiza el momento GEO. CTAs: primario a /contacto, secundario a la
 * prueba GEO. Los capítulos editoriales antiguos quedan en el repo, fuera
 * de uso, hasta decidir su salvado.
 */
import PageLayout from '../layouts/PageLayout.astro'
import BrandPetals from '../components/astro/ui/BrandPetals.astro'
import MethodDiagram from '../components/astro/ui/MethodDiagram.astro'

const services = [
  {
    name: 'Diseño y desarrollo web + GEO',
    desc: 'Webs que cargan rápido, convierten y aparecen cuando tus clientes preguntan a una IA.',
  },
  {
    name: 'Auditoría AI Readiness',
    desc: 'Evaluamos sin humo si la IA aporta algo real a tu empresa y por dónde tiene sentido empezar.',
  },
  {
    name: 'Software a medida',
    desc: 'Herramientas hechas para tu proceso concreto, no plantillas a las que te toca adaptarte.',
  },
  {
    name: 'Consultoría TIC',
    desc: 'Criterio técnico para decidir bien antes de gastar, con alguien que te habla claro.',
  },
]
---

<PageLayout
  title="Zanovix — IA aplicada a empresas"
  description="IA aplicada con ingeniería pausada. Aparece cuando tus clientes preguntan a una IA y deja de contestar a mano lo de siempre. Pruébalo aquí mismo."
  page="home"
>
  <!-- ── Hero: el mensaje firmado + CTAs claros ──────────────────── -->
  <section id="hero" class="hero" aria-labelledby="hero-title">
    <div class="hero__text">
      <h1 id="hero-title" class="display hero__title">
        Tus clientes ya le preguntan a una IA.
      </h1>
      <p class="hero__lede">
        Si ahí no apareces, para ellos no existes, y ni te enteras. Lo primero
        que hacemos es ponerte donde te buscan; lo segundo, que dejes de
        contestar a mano lo de siempre.
      </p>
      <div class="hero__cta-row">
        <a class="cta-primary" href="/contacto" data-open-contact data-contact-origin="home-hero">Cuéntanos tu caso</a>
        <a class="cta-ghost" href="/servicios/diseno-desarrollo-web-geo">
          Mira cómo te ve una IA hoy
          <span class="cta-ghost__arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <p class="hero__sign">IA aplicada, con ingeniería pausada.</p>
    </div>

    <!-- Apoyo visual sobrio: la escena que nombra el hero, no un demo.
         Markup decorativo (aria-hidden), construido con el sistema v2.
         No es stock ni la herramienta interactiva: esa vive en /servicios. -->
    <div class="hero__scene" aria-hidden="true">
      <BrandPetals tone="paper" corner="bottom-right" size={220} />
      <p class="hero__scene-head">
        <span class="hero__scene-dot"></span>
        Una IA, ahora mismo
      </p>
      <p class="hero__scene-ask">
        “¿Qué <span class="hero__scene-mark">restaurante</span> me recomiendas
        en <span class="hero__scene-mark">Málaga</span>?”
      </p>
      <ul class="hero__scene-list">
        <li class="hero__scene-item">Te nombra a otros tres del barrio.</li>
        <li class="hero__scene-item">A ti no te menciona.</li>
        <li class="hero__scene-item hero__scene-item--quiet">
          Y el cliente nunca sabrá que existías.
        </li>
      </ul>
      <p class="hero__scene-foot">Eso es lo primero que arreglamos.</p>
    </div>
  </section>

  <!-- ── Lo que hacemos ──────────────────────────────────────────── -->
  <section class="services" aria-labelledby="services-title">
    <div class="services__head">
      <h2 id="services-title" class="display services__title">Lo que hacemos</h2>
      <p class="services__lede">
        Cuatro maneras de bajar la IA a tu negocio. Empezamos por lo que de
        verdad te mueve la aguja, no por lo que suena bien.
      </p>
    </div>
    <ul class="services__list">
      {
        services.map((s) => (
          <li class="services__item">
            <h3 class="services__name">{s.name}</h3>
            <p class="services__desc">{s.desc}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ── Radiografia GEO: preview fiel del resultado real ────────────
   * No es un mockup falso ni stock: es una REPRODUCCION del propio resultado
   * que devuelve el producto (la radiografia GEO en vivo, GeoSimulator). Se
   * muestra el momento honesto que vende: "una IA no te conoce todavia". Las
   * clases .geosim__* son LAS MISMAS del componente real (global.css), asi
   * que el preview es fiel pixel a pixel, no una imitacion. Es estatico
   * (aria-hidden) porque la herramienta interactiva vive en /servicios, donde
   * pide el nombre real; aqui solo enseña como se ve para invitar a probarla.
   -->
  <section class="proof" aria-labelledby="proof-title">
    <div class="proof__inner">
      <div class="proof__text">
        <h2 id="proof-title" class="display proof__title">
          Mira cómo te ve una IA hoy.
        </h2>
        <p class="proof__lede">
          Le preguntamos en vivo a una IA por el nombre real de tu negocio. Si
          eres una pyme, lo normal es que no te conozca todavía. Eso no es malo:
          es exactamente lo primero que arreglamos.
        </p>
        <p class="proof__note">
          Esto es lo que verías al hacer la prueba con tu negocio. La de verdad,
          con tu nombre, está a un clic.
        </p>
        <a
          class="cta-primary"
          href="/servicios/diseno-desarrollo-web-geo"
        >
          Hacer mi radiografía GEO
        </a>
      </div>

      <!-- Reproduccion fiel del resultado del producto (estatica, decorativa).
           Mundo forest, mismas clases que el GeoSimulator real. -->
      <div class="proof__demo" aria-hidden="true">
        <div class="geosim">
          <BrandPetals tone="paper" corner="top-right" size={180} />
          <p class="geosim__head">
            <span class="geosim__dot"></span>
            Radiografía GEO en vivo
          </p>
          <p class="geosim__verdict">Una IA no te conoce todavía</p>
          <dl class="geosim__dl">
            <div class="geosim__item">
              <dt>Qué sabe de ti</dt>
              <dd>
                No tengo información sobre un negocio con ese nombre en esa zona.
              </dd>
            </div>
            <div class="geosim__item">
              <dt>Si te recomendaría</dt>
              <dd>
                Al preguntar por tu categoría, nombraría a otros antes que a ti.
              </dd>
            </div>
            <div class="geosim__item">
              <dt>Qué le falta</dt>
              <dd>
                Señales claras de quién eres, dónde estás y qué haces, donde la
                IA las pueda leer.
              </dd>
            </div>
          </dl>
          <p class="geosim__note">
            Respuesta real del modelo. Aquí es donde entramos nosotros.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tira del metodo: diagrama a medida ───────────────────────────
   * Mundo forest "drenched" deliberado: rompe la planicie tipografica con un
   * momento de color y enseña el metodo como FLUJO (no como mas texto). El
   * diagrama explica que el orden importa y dirige a /metodologia. Significado,
   * no relleno: para el comprador economico, el metodo ES la prueba del rigor.
   -->
  <section class="method" aria-labelledby="method-title">
    <div class="method__inner">
      <BrandPetals tone="paper" corner="top-left" size={300} />
      <header class="method__head">
        <h2 id="method-title" class="display method__title">
          Cómo trabajamos, en cuatro pasos.
        </h2>
        <p class="method__lede">
          Siempre el mismo orden, porque el orden importa. No proponemos sin
          entender, no construimos sin medir y no entregamos sin documentar.
        </p>
      </header>
      <MethodDiagram variant="strip" tone="forest" withLink={true} />
    </div>
  </section>

  <!-- ── Handoff a contacto ──────────────────────────────────────── -->
  <section id="contacto" class="contact" aria-labelledby="contact-title">
    <h2 id="contact-title" class="display contact__title">
      Cuando quieras, seguimos en una conversación.
    </h2>
    <p class="contact__lede">
      Sin formularios eternos ni promesas grandes. Nos cuentas tu caso y te
      decimos con honestidad si podemos ayudarte y cómo.
    </p>
    <a class="cta-primary" href="/contacto" data-open-contact data-contact-origin="home-cierre">Contar mi caso</a>
    <p class="cta-fallback">
      Si lo prefieres, escríbenos directo a
      <a href="mailto:info@zanovix.com">info@zanovix.com</a>.
    </p>
    <p class="contact__meta">Málaga · ES · respondemos en menos de 24h hábiles</p>
  </section>
</PageLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--spacing-hero-y) var(--spacing-section-x);
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 880px) {
    .hero {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }
  .hero__title {
    font-size: var(--text-display);
    color: var(--color-ink);
    margin: 0 0 1.25rem;
    max-width: 16ch;
  }
  .hero__lede {
    font-size: var(--text-lede);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 52ch;
    margin: 0 0 1.75rem;
  }
  .hero__cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
    margin: 0 0 1.75rem;
  }
  .hero__sign {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.06em;
    color: var(--ink-mute);
    margin: 0;
  }

  /* ── Apoyo visual del hero (escena GEO, decorativa) ───────────────
   * No es la herramienta interactiva: es una escena estatica que dramatiza
   * el mensaje. Mundo "drenched" forest, coherente con el sistema. Texto
   * paper sobre forest (tintas AA en :root). El teal solo como acento.
   */
  .hero__scene {
    position: relative;
    overflow: hidden;
    background: var(--color-forest);
    color: var(--paper-on-dark);
    border: 1px solid var(--color-rule-invert);
    border-radius: 16px;
    padding: clamp(1.5rem, 2vw + 1rem, 2.25rem);
    font-family: var(--font-sans);
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  /* El texto de la escena por encima del motivo de marca (marca de agua). */
  .hero__scene > :not(.brandpetals) {
    position: relative;
    z-index: 1;
  }
  .hero__scene-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--paper-on-dark-mute);
    margin: 0 0 1.25rem;
  }
  .hero__scene-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-teal-bright);
    flex: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__scene-dot {
      animation: heroSceneDot 2.4s ease-in-out infinite;
    }
  }
  @keyframes heroSceneDot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .hero__scene-ask {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 600;
    line-height: 1.3;
    color: var(--paper-on-dark);
    margin: 0 0 1.5rem;
    max-width: 26ch;
  }
  .hero__scene-mark {
    color: var(--color-teal-bright);
  }
  .hero__scene-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .hero__scene-item {
    position: relative;
    padding-left: 1.4rem;
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--paper-on-dark-soft);
  }
  .hero__scene-item::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--color-teal-bright);
  }
  .hero__scene-item--quiet {
    color: var(--paper-on-dark-mute);
  }
  .hero__scene-item--quiet::before {
    color: var(--paper-on-dark-mute);
  }
  .hero__scene-foot {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.04em;
    color: var(--color-teal-bright);
    margin: 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-rule-invert);
  }

  /* CTA secundario "fantasma": claro, subrayado teal, sin competir con
     el primario ink. */
  .cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-body);
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 2px solid var(--color-teal-deep);
    transition: border-color 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-ghost:hover {
    border-color: var(--color-teal);
  }
  .cta-ghost:focus-visible {
    outline: 2px solid var(--color-ink);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .cta-ghost__arrow {
    transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: no-preference) {
    .cta-ghost:hover .cta-ghost__arrow {
      transform: translateX(3px);
    }
  }

  /* ── Servicios ────────────────────────────────────────────────── */
  .services {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--spacing-section-y) var(--spacing-section-x);
  }
  .services__head {
    max-width: 60ch;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .services__title {
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin: 0 0 0.75rem;
  }
  .services__lede {
    font-size: var(--text-lede);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }
  .services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .services__item {
    display: grid;
    gap: 0.4rem;
    padding: clamp(1.25rem, 2.5vw, 2rem) 0;
    border-top: 1px solid var(--color-rule);
  }
  .services__item:last-child {
    border-bottom: 1px solid var(--color-rule);
  }
  @media (min-width: 720px) {
    .services__item {
      grid-template-columns: minmax(0, 22rem) 1fr;
      gap: clamp(1.5rem, 4vw, 4rem);
      align-items: baseline;
    }
  }
  .services__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-h3);
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
  }
  .services__desc {
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    max-width: 52ch;
  }

  /* ── Prueba GEO (preview fiel del resultado real) ─────────────────── */
  .proof {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--spacing-section-y) var(--spacing-section-x);
  }
  .proof__inner {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 880px) {
    .proof__inner {
      grid-template-columns: 0.95fr 1.05fr;
    }
  }
  .proof__title {
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin: 0 0 1rem;
    max-width: 16ch;
  }
  .proof__lede {
    font-size: var(--text-lede);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 50ch;
    margin: 0 0 1.25rem;
  }
  .proof__note {
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--ink-mute-strong);
    max-width: 48ch;
    margin: 0 0 1.75rem;
  }
  /* El panel forest del preview lleva el motivo de marca recortado: necesita
     contexto de recorte propio (el componente .geosim no lo trae). */
  .proof__demo .geosim {
    position: relative;
    overflow: hidden;
  }
  .proof__demo .geosim > :not(.brandpetals) {
    position: relative;
    z-index: 1;
  }

  /* ── Tira del metodo (mundo forest drenched) ──────────────────────── */
  .method {
    background: var(--color-forest);
    color: var(--paper-on-dark);
  }
  .method__inner {
    position: relative;
    overflow: hidden;
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--spacing-section-y) var(--spacing-section-x);
  }
  .method__inner > :not(.brandpetals) {
    position: relative;
    z-index: 1;
  }
  .method__head {
    max-width: 56ch;
    margin-bottom: clamp(2rem, 4vw, 3.25rem);
  }
  .method__title {
    font-size: var(--text-h1);
    color: var(--paper-on-dark);
    margin: 0 0 0.85rem;
    max-width: 18ch;
  }
  .method__lede {
    font-size: var(--text-lede);
    line-height: 1.6;
    color: var(--paper-on-dark-soft);
    max-width: 54ch;
    margin: 0;
  }

  /* ── Contacto ─────────────────────────────────────────────────── */
  .contact {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: var(--spacing-section-y) var(--spacing-section-x);
  }
  .contact__title {
    font-size: var(--text-h1);
    color: var(--color-ink);
    margin: 0 0 1rem;
    max-width: 18ch;
  }
  .contact__lede {
    font-size: var(--text-lede);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 50ch;
    margin: 0 0 2rem;
  }
  .contact__mail {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 3vw + 0.5rem, 2.75rem);
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-teal-deep);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.3em;
    display: inline-block;
    margin-bottom: 1.75rem;
    transition: text-decoration-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .contact__mail:hover {
    text-decoration-color: var(--color-teal);
  }
  .contact__meta {
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    letter-spacing: 0.05em;
    color: var(--ink-mute);
    margin: 1.75rem 0 0;
  }
</style>
